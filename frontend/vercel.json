{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "${NEXT_PUBLIC_API_BASE_URL:-https://nexusos-api.up.railway.app}/api/:path*"
    }
  ],
  "env": {
    "NEXT_PUBLIC_API_BASE_URL": "@nexusos-api-url"
  }
}
